---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ko-KR', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="아카이브 | 온의 기술 노트">
  <main class="article">
    <h1>아카이브</h1>
    <p class="article-description">생성된 모든 기술 글을 최신순으로 모아둡니다.</p>
  </main>

  {posts.length === 0 ? (
    <p class="empty">아직 공개된 글이 없습니다.</p>
  ) : (
    <section class="post-grid" aria-label="All posts">
      {posts.map((post) => (
        <article class="post-card">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <div>
            <h2>
              <a href={`${base}posts/${post.id}/`}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </section>
  )}
</BaseLayout>
